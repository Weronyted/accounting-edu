rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    // Replace CdeioQnkZPdcUEqVXrkT7BTU0SD2 with your Firebase UID (find it in Firebase Console → Auth)
    function isOwner() {
      return isAuth() && request.auth.uid == 'CdeioQnkZPdcUEqVXrkT7BTU0SD2';
    }

    function getRole() {
      return get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuth() && (isOwner() || getRole() == 'admin');
    }

    function isTeacher() {
      return isAuth() && (isOwner() || getRole() in ['admin', 'teacher']);
    }

    // ─── User Roles ──────────────────────────────────────────────────────────
    // Stores { role, displayName, email } for every user.

    match /userRoles/{uid} {
      // Users can read their own role; admins can read all
      allow get: if isAuth() && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();

      // Anyone authenticated can create their own doc (initial sign-up, role = student)
      allow create: if isAuth()
        && request.auth.uid == uid
        && request.resource.data.role == 'student';

      // Owner can set any role; admins can only set teacher / student
      // Users can update only their own displayName (not role)
      allow update: if isOwner()
        || (isAdmin() && request.resource.data.role in ['teacher', 'student'])
        || (isAuth() && request.auth.uid == uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName']));

      // Admins and owner can delete user role records
      allow delete: if isAdmin() || isOwner();
    }

    // ─── Private user data ───────────────────────────────────────────────────

    match /users/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;

      match /progress/{topicSlug} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }

      match /quizHistory/{docId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }

      match /meta/{docId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }
    }

    // ─── Dynamic Lessons ─────────────────────────────────────────────────────
    // Created by admins; visible to all authenticated users once published.

    match /dynamicLessons/{lessonId} {
      allow read: if isAuth() && (resource.data.published == true || isAdmin());
      allow list: if isAuth();  // filtered client-side by published flag
      allow create, update, delete: if isAdmin();
    }

    // ─── Assignments ─────────────────────────────────────────────────────────
    // Teachers create assignments; admins manage all.

    match /assignments/{assignmentId} {
      allow read: if isAuth() && (resource.data.published == true || isAdmin()
        || (isTeacher() && resource.data.teacherId == request.auth.uid));
      allow list: if isAuth();
      allow create: if isTeacher()
        && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isAdmin()
        || (isTeacher() && resource.data.teacherId == request.auth.uid);

      // Student submissions — students write their own, teachers/admins read all
      match /submissions/{submissionId} {
        allow create: if isAuth()
          && request.resource.data.userId == request.auth.uid;
        allow read: if isAuth() && (
          resource.data.userId == request.auth.uid || isTeacher() || isAdmin()
        );
        allow list: if isAuth();
      }
    }

    // ─── Teacher Profiles ────────────────────────────────────────────────────
    // Stores Google Classroom access tokens; only visible to the teacher.

    match /teacherProfiles/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
      allow read: if isAdmin();
    }

    // ─── Class Groups ────────────────────────────────────────────────────────
    // Teachers create classes; students can read classes they belong to.

    match /classGroups/{classId} {
      allow read: if isAuth() && (
        resource.data.teacherId == request.auth.uid
        || exists(/databases/$(database)/documents/classGroups/$(classId)/members/$(request.auth.uid))
        || (exists(/databases/$(database)/documents/userClasses/$(request.auth.uid))
            && get(/databases/$(database)/documents/userClasses/$(request.auth.uid)).data.classId == classId)
        || isAdmin()
      );
      allow list: if true;  // invite links must work for unauthenticated users
      allow create: if isTeacher()
        && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isAdmin()
        || (isTeacher() && resource.data.teacherId == request.auth.uid);

      match /members/{memberId} {
        // Any authenticated user can join (create their own member doc)
        allow create: if isAuth() && request.auth.uid == memberId;
        // Members can read the member list of their class; teacher and admin too
        allow read, list: if isAuth() && (
          request.auth.uid == memberId
          || get(/databases/$(database)/documents/classGroups/$(classId)).data.teacherId == request.auth.uid
          || exists(/databases/$(database)/documents/classGroups/$(classId)/members/$(request.auth.uid))
          || isAdmin()
        );
        allow delete: if isAdmin()
          || get(/databases/$(database)/documents/classGroups/$(classId)).data.teacherId == request.auth.uid;
      }
    }

    // ─── User → Class mapping ────────────────────────────────────────────────
    // Each student stores which class they belong to.

    match /userClasses/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
      allow read: if isAdmin();
    }

    // ─── Deny everything else ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
