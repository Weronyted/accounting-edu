rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    // Replace CdeioQnkZPdcUEqVXrkT7BTU0SD2 with your Firebase UID (find it in Firebase Console → Auth)
    function isOwner() {
      return isAuth() && request.auth.uid == 'CdeioQnkZPdcUEqVXrkT7BTU0SD2';
    }

    function getRole() {
      return get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuth() && (isOwner() || getRole() == 'admin');
    }

    function isTeacher() {
      return isAuth() && (isOwner() || getRole() in ['admin', 'teacher']);
    }

    // ─── User Roles ──────────────────────────────────────────────────────────
    // Stores { role, displayName, email } for every user.

    match /userRoles/{uid} {
      // Users can read their own role; admins can read all
      allow get: if isAuth() && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();

      // Anyone authenticated can create their own doc (initial sign-up, role = student)
      allow create: if isAuth()
        && request.auth.uid == uid
        && request.resource.data.role == 'student';

      // Owner can set any role; admins can only set teacher / student
      allow update: if isOwner()
        || (isAdmin() && request.resource.data.role in ['teacher', 'student']);
    }

    // ─── Private user data ───────────────────────────────────────────────────

    match /users/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;

      match /progress/{topicSlug} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }

      match /quizHistory/{docId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }

      match /meta/{docId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }
    }

    // ─── Dynamic Lessons ─────────────────────────────────────────────────────
    // Created by admins; visible to all authenticated users once published.

    match /dynamicLessons/{lessonId} {
      allow read: if isAuth() && (resource.data.published == true || isAdmin());
      allow list: if isAuth();  // filtered client-side by published flag
      allow create, update, delete: if isAdmin();
    }

    // ─── Assignments ─────────────────────────────────────────────────────────
    // Teachers create assignments; admins manage all.

    match /assignments/{assignmentId} {
      allow read: if isAuth() && (resource.data.published == true || isAdmin()
        || (isTeacher() && resource.data.teacherId == request.auth.uid));
      allow list: if isTeacher() || isAdmin();
      allow create: if isTeacher()
        && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isAdmin()
        || (isTeacher() && resource.data.teacherId == request.auth.uid);

      // Student submissions — students write their own, teachers/admins read all
      match /submissions/{submissionId} {
        allow create: if isAuth()
          && request.resource.data.userId == request.auth.uid;
        allow read: if isAuth() && (
          resource.data.userId == request.auth.uid || isTeacher() || isAdmin()
        );
        allow list: if isTeacher() || isAdmin();
      }
    }

    // ─── Teacher Profiles ────────────────────────────────────────────────────
    // Stores Google Classroom access tokens; only visible to the teacher.

    match /teacherProfiles/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
      allow read: if isAdmin();
    }

    // ─── Deny everything else ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
